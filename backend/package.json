{
  "name": "kanadojo-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend service for KanaDojo flashcard processing and authentication",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run init-db && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "init-db": "node scripts/init-db.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset --force",
    "seed:admin": "tsx src/scripts/seedAdmin.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "translate-google": "^1.5.0",
    "youtube-transcript-plus": "^2.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.1",
    "prisma": "^6.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
