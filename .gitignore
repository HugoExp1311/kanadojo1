# Auto-Generated Dictionary Shards
# The SOURCE files (data/kanji_dict.json, data/vocab_dict.json) ARE committed.
# The shards below are GENERATED by scripts/shard_dictionaries.js at Docker build time.
/frontend/public/data-wanikani/kanji/*.json
/frontend/public/data-wanikani/vocab/*.json
/frontend/public/data-wanikani/kanji_vi/*.json
/frontend/public/data-wanikani/vocab_vi/*.json

